{
  "name": "beefor-dev",
  "version": "0.1.15",
  "description": "Beefor Dev - desktop automation for Beefor",
  "main": "dist/main/index.js",
  "author": "Joao Batista",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "predev": "node scripts/free-port.mjs 5177 && node scripts/build-preload.mjs",
    "dev": "concurrently -k -n vite,tsc,preload,electron \"npm:dev:renderer\" \"npm:dev:tsc\" \"npm:dev:preload\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:tsc": "tsc -p tsconfig.main.json -w --preserveWatchOutput",
    "dev:preload": "node scripts/watch-preload.mjs",
    "dev:electron": "wait-on tcp:5177 file:dist/main/index.js file:dist/main/preload.js && cross-env NODE_ENV=development electron .",
    "kill:port": "node scripts/free-port.mjs 5177",
    "codes:hash": "node scripts/hash-codes.mjs",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json && node scripts/build-preload.mjs",
    "build": "npm run build:renderer && npm run build:main",
    "start": "electron .",
    "package:win": "npm run build && electron-builder --win --publish always",
    "package:mac": "npm run build && electron-builder --mac --publish always",
    "test": "vitest run",
    "lint": "tsc --noEmit && eslint src --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "electron-log": "^5.1.5",
    "electron-updater": "^6.8.3",
    "keytar": "^7.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "i18next": "^26.1.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.7",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.0.5",
    "wait-on": "^7.2.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0"
    ]
  },
  "build": {
    "appId": "io.beefor.dev",
    "productName": "Beefor Dev",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "build/**/*",
      "package.json"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "patch-journal.md",
        "to": "patch-journal.md"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Beefor",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "runAfterFinish": true,
      "menuCategory": "Beefor"
    },
    "publish": {
      "provider": "github",
      "owner": "jhb404",
      "repo": "BeeforDev",
      "releaseType": "release"
    }
  }
}
